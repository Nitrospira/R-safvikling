<!DOCTYPE html>
<html lang="da">
<head>
<meta charset="UTF-8">
<title>Race Control</title>

<style>
body {
  background:black;
  color:white;
  text-align:center;
  font-family:Arial;
}

.lights {
  display:flex;
  justify-content:center;
  margin:40px;
}

.light {
  width:40px;
  height:40px;
  margin:10px;
  border-radius:50%;
  background:#330000;
}

.on {
  background:red;
}

#timer {
  font-size:60px;
  margin:20px;
}

#flag {
  display:none;
  position:fixed;
  top:0;
  left:0;
  width:100%;
  height:100%;
  background:url('https://upload.wikimedia.org/wikipedia/commons/2/2f/Checkered_flag.svg');
  background-size:cover;
}
</style>
</head>

<body>

<h1>🏁 Race Control</h1>

<label>Varighed (min): </label>
<input type="number" id="minutes" min="1" max="15" value="5">

<br><br>

<button onclick="startSequence()">START LØB</button>

<div class="lights">
  <div class="light" id="l1"></div>
  <div class="light" id="l2"></div>
  <div class="light" id="l3"></div>
  <div class="light" id="l4"></div>
  <div class="light" id="l5"></div>
</div>

<div id="timer">00:00</div>

<div id="flag"></div>

<script>

function speak(text) {
  let msg = new SpeechSynthesisUtterance(text);
  speechSynthesis.speak(msg);
}

function sleep(ms) {
  return new Promise(r => setTimeout(r, ms));
}

async function startSequence() {

  speak("Gentlemen, start your engines");

  let lights = ["l1","l2","l3","l4","l5"];

  for (let i = 0; i < lights.length; i++) {
    document.getElementById(lights[i]).classList.add("on");
    await sleep(800);
  }

  await sleep(1000);

  lights.forEach(l => document.getElementById(l).classList.remove("on"));

  startRace();
}

function startRace() {

  let min = document.getElementById("minutes").value;
  let time = min * 60;

  let timer = setInterval(() => {

    let m = Math.floor(time / 60);
    let s = time % 60;

    document.getElementById("timer").innerText =
      String(m).padStart(2,'0') + ":" + String(s).padStart(2,'0');

    time--;

    if (time < 0) {
      clearInterval(timer);
      endRace();
    }

  }, 1000);
}

function endRace() {
  document.getElementById("flag").style.display = "block";
  speak("The race is over");
}

</script>

</body>
</html>
